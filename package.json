{
  "name": "foodiq",
  "version": "4.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:clean": "node scripts/dev.mjs --clean",
    "dev:backend": "node scripts/dev-backend.mjs",
    "dev:verify": "node scripts/verify-dev.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit",
    "test:unit": "node scripts/run-unit-tests.js tests/unit",
    "test:ui": "node scripts/ui-smoke.mjs",
    "ci": "npm run lint && npm run typecheck && npm run test:unit && npm run seo:validate && npm run perf:validate && npm run mobile:validate && npm run security:validate && npm run build",
    "seo:report": "node scripts/generate-seo-report.mjs",
    "audit:report": "node scripts/generate-production-audit-report.mjs",
    "seo:validate": "node scripts/validate-jsonld.mjs && node scripts/validate-technical-seo.mjs && node scripts/validate-social-metadata.mjs",
    "perf:hero-assets": "node scripts/optimize-hero-assets.mjs",
    "perf:validate": "node scripts/validate-performance.mjs",
    "perf:report": "node scripts/generate-performance-report.mjs",
    "mobile:validate": "node scripts/validate-mobile-seo.mjs",
    "security:validate": "node scripts/validate-security-headers.mjs",
    "seo:icons": "node scripts/generate-seo-icons.js",
    "seo:social-images": "node scripts/generate-social-images.js",
    "pwa:icons": "node scripts/generate-pwa-icons.js",
    "postbuild": "node scripts/generate-seo-report.mjs && node scripts/generate-performance-report.mjs && node scripts/generate-production-audit-report.mjs",
    "images:build": "node scripts/buildDishImages.js",
    "build:cf": "opennextjs-cloudflare build",
    "deploy:cf": "opennextjs-cloudflare build && wrangler deploy",
    "analyze": "next build"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "date-fns": "^4.4.0",
    "firebase": "^12.16.0",
    "framer-motion": "^12.42.2",
    "js-cookie": "^3.0.8",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.35.3",
    "socket.io-client": "^4.8.3",
    "swr": "^2.4.2"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "esbuild": "^0.25.4"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@tailwindcss/postcss": "^4",
    "@types/js-cookie": "^3.0.6",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^7",
    "wrangler": "^4.112.0"
  }
}
