# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:4000
# Public site URL used for canonicals, sitemap, Open Graph (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Optional Google Search Console verification meta content
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# --- Analytics & monitoring (production only) ---
# Leave unset locally — scripts/events no-op when NODE_ENV !== production
# NEXT_PUBLIC_ANALYTICS_ENABLED=true
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
# NEXT_PUBLIC_CLARITY_ID=xxxxxxxxxxxx
# NEXT_PUBLIC_MONITORING_ENABLED=true
# NEXT_PUBLIC_VERBOSE_LOGGING=false
# Optional publishable key (server returns key_id from create-order — preferred)
# NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxx

# Backend (foodiq-frontend/foodiq-backend/.env)
# PORT=4000
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=
# DB_NAME=foodiq
# DATABASE_URL=
# JWT_SECRET=replace-with-openssl-rand-hex-32-minimum-thirty-two-chars
# JWT_REFRESH_SECRET=optional-separate-64-hex-secret-for-refresh-tokens
# FRONTEND_URL=http://localhost:3000
# Production CORS:
# FRONTEND_URL=https://foodiq-sangita123-as-projects.vercel.app
# CORS_STRICT=true
# CORS_ALLOW_VERCEL=false
# AUTH_SECURE_COOKIES=true
# CSRF_ENABLED=true
# FORCE_HTTPS=true
# DATA_ENCRYPTION_KEY=
# BCRYPT_ROUNDS=12
# RAZORPAY_MOCK=false
# ALLOW_PAYMENT_MOCK=false
# ALLOW_BOOTSTRAP_USERS=false
#
# Socket.IO shares the same API port (no extra URL).
# Frontend connects to NEXT_PUBLIC_API_URL with JWT cookie `token`.
# See foodiq-frontend/foodiq-backend/docs/SOCKET_IO.md
#
# --- Firebase Cloud Messaging (Web Push) ---
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_VAPID_KEY=
# NEXT_PUBLIC_FCM_MOCK_TOKEN=true
#
# --- Razorpay ---
# Test mode: Dashboard → Settings → API Keys → Generate Test Key
# RAZORPAY_KEY_ID=rzp_test_xxxxx
# RAZORPAY_KEY_SECRET=xxxxx
# RAZORPAY_MOCK=false
# Webhook URL: https://YOUR_API/api/payments/webhook
# Events: payment.captured, payment.failed, refund.processed, refund.failed
# RAZORPAY_WEBHOOK_SECRET=whsec_xxxxx
#
# Local without keys: leave KEY empty or RAZORPAY_MOCK=true (signed mock checkout)
# Test cards: https://razorpay.com/docs/payments/payments/test-card-details/
# Test UPI: success@razorpay / failure@razorpay
#
# --- Email / SMS (backend) ---
# EMAIL_PROVIDER=mock|smtp|resend|sendgrid
# SMS_PROVIDER=mock|twilio|msg91|fast2sms
# See foodiq-frontend/foodiq-backend/docs/EMAIL_SMS.md
# Customer prefs UI: /notification-preferences
#
# --- Cloud Storage (backend) ---
# STORAGE_PROVIDER=auto|cloudinary|s3|mock
# CLOUDINARY_CLOUD_NAME= / CLOUDINARY_API_KEY= / CLOUDINARY_API_SECRET=
# See foodiq-frontend/foodiq-backend/docs/CLOUD_STORAGE.md
#
# --- Monitoring / Security ---
# Admin UI: /admin/monitoring
# Docs: foodiq-frontend/foodiq-backend/docs/MONITORING_SECURITY.md
#
# --- CI/CD ---
# Docs: docs/CICD.md · docs/SECRETS.md
# Secrets live in GitHub Environments — never commit real values.

