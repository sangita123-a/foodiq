PORT=4000
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=foodiq
# DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres?sslmode=require
# Production (Render): DATABASE_URL is injected from the Render Postgres instance
# DB_SSL=true
JWT_SECRET=replace-with-openssl-rand-hex-32-minimum-thirty-two-chars
# JWT_REFRESH_SECRET=optional-separate-64-hex-secret-for-refresh-tokens
FRONTEND_URL=http://localhost:3000
# Production CORS (comma-separated extras beyond FRONTEND_URL)
# CORS_ORIGINS=https://your-app.vercel.app
# CORS_STRICT defaults true in production
CORS_STRICT=true
# CORS_ALLOW_VERCEL=false

# Optional AES-256 key for PII field encryption (64 hex chars)
# DATA_ENCRYPTION_KEY=
# FORCE_HTTPS=true

# Razorpay — https://dashboard.razorpay.com
# Test Mode keys for development; Live keys for production.
# Set RAZORPAY_MOCK=true (or leave keys empty) for local signed mock payments.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_MOCK=true

# Webhook secret from Dashboard → Settings → Webhooks
# Endpoint: POST {API_URL}/api/payments/webhook
# Subscribe: payment.captured, payment.failed, refund.processed, refund.failed
RAZORPAY_WEBHOOK_SECRET=

# --- Test Mode checklist ---
# 1. Create Test API keys in Razorpay Dashboard
# 2. Set RAZORPAY_KEY_ID / RAZORPAY_KEY_SECRET and RAZORPAY_MOCK=false
# 3. Dummy cards: https://razorpay.com/docs/payments/payments/test-card-details/
#    Success: 4111 1111 1111 1111 | CVV any | Expiry any future
# 4. UPI test: success@razorpay (success) / failure@razorpay (failure)
# 5. Forward webhooks locally with ngrok/cloudflare tunnel to /api/payments/webhook

# --- Firebase Cloud Messaging ---
# Leave FCM_MOCK=true for local logged pushes without Firebase.
FCM_MOCK=true
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_VAPID_KEY=
# See docs/PUSH_NOTIFICATIONS.md

# --- Email (Nodemailer / Resend / SendGrid) ---
# mock | smtp | resend | sendgrid — mock logs to console + email_logs
EMAIL_PROVIDER=mock
EMAIL_FROM=Foodiq <noreply@foodiq.com>
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# RESEND_API_KEY=
# SENDGRID_API_KEY=
# EMAIL_FROM_ADDRESS=noreply@foodiq.com
# EMAIL_FROM_NAME=Foodiq

# --- SMS (Twilio / MSG91 / Fast2SMS) ---
SMS_PROVIDER=mock
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# MSG91_AUTH_KEY=
# MSG91_SENDER_ID=FOODIQ
# MSG91_TEMPLATE_ID=
# FAST2SMS_API_KEY=

# --- OTP ---
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RATE_WINDOW_MIN=15
OTP_RATE_MAX=5
# OTP_EXPOSE_CODE=true
# See docs/EMAIL_SMS.md

# --- Cloud Storage (Cloudinary / S3 / mock) ---
# auto picks Cloudinary if configured, else S3, else local mock
STORAGE_PROVIDER=auto
API_PUBLIC_URL=http://localhost:4000
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# S3_BUCKET=
# S3_REGION=ap-south-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_CDN_URL=
# See docs/CLOUD_STORAGE.md

# --- Monitoring / Security ---
LOG_LEVEL=info
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d
METRICS_INTERVAL_MS=60000
TRUST_PROXY=true
# Production: CORS_STRICT=true, CORS_ALLOW_VERCEL=false, FRONTEND_URL=https://your-app.vercel.app
CORS_STRICT=true
CORS_ALLOW_VERCEL=false
# CSRF defaults to on in production; Bearer Authorization is exempt
CSRF_ENABLED=true
# HttpOnly auth cookies (defaults on). Use AUTH_SECURE_COOKIES=false only for rare local debugging.
AUTH_SECURE_COOKIES=true
# AUTH_COOKIE_SAMESITE=none
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=7d
# JWT_REFRESH_SECRET=
BCRYPT_ROUNDS=12
ALLOW_BOOTSTRAP_USERS=false
ALLOW_PAYMENT_MOCK=false
RATE_LIMIT_API_MAX=300
RATE_LIMIT_AUTH_MAX=30
RATE_LIMIT_OTP_MAX=10
RATE_LIMIT_UPLOAD_MAX=40
RATE_LIMIT_CONTACT_MAX=8
# See docs/MONITORING_SECURITY.md

# --- Performance / Redis cache ---
# Without Redis, in-memory cache is used automatically
# REDIS_URL=redis://127.0.0.1:6379
# REDIS_ENABLED=true
CACHE_TTL_SECONDS=60
CACHE_TTL_RESTAURANTS=45
CACHE_TTL_MENU=60
CACHE_TTL_CATEGORIES=300
CACHE_TTL_OFFERS=120
CACHE_TTL_SESSION=30
CACHE_TTL_SEARCH=30
CACHE_TTL_SUGGEST=45
# CACHE_CONTROL_PUBLIC=public, max-age=30, s-maxage=60, stale-while-revalidate=120
# SLOW_REQUEST_MS=500
DB_POOL_MAX=20
DB_STATEMENT_TIMEOUT_MS=15000
SOCKET_REDIS_ADAPTER=true
# See docs/PERFORMANCE.md
#
# --- CI/CD ---
# Migrations in Actions: npm run db:migrate && npm run db:verify
# Platform secrets: see /docs/SECRETS.md (never commit real keys)
